# ============================================================================
# Oil-Gas VLM — 环境变量样例
# 复制为 .env（已被 .gitignore 忽略），填入你的真实值
#
#   cp .env.example .env
#
# 也可以直接 export / set 而不写 .env。
# ============================================================================

# ----- 后端选择 ------------------------------------------------------------
# local（默认，需 GPU + QWEN_VL_PATH）| api（OpenAI 兼容，需 VLM_API_KEY）
# 默认 local：避免用户没意识到时产生 API 费用
VLM_BACKEND=api

# ----- API 后端 ------------------------------------------------------------
# 密钥优先级：VLM_API_KEY > DASHSCOPE_API_KEY
# 永远不要把真实 key 提交到 git —— .env 已在 .gitignore 中
VLM_API_KEY=
DASHSCOPE_API_KEY=

# DashScope 兼容模式（请替换成你实际的 workspace id）
VLM_BASE_URL=https://YOUR_WORKSPACE_ID.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
VLM_MODEL=qwen3-vl-plus

# 网络与生成
VLM_TIMEOUT=180
VLM_MAX_TOKENS=6144
VLM_TEMPERATURE=0.1

# 网络错误有限重试（与 schema 重试独立）
VLM_API_MAX_RETRIES=2

# 是否传 response_format={"type":"json_object"}
# 第一轮建议 false：extract_json + schema 重试已能统一处理
VLM_API_JSON_MODE=false

# 图片预处理（0=不缩放，推荐第一轮 A/B 用原图）
VLM_API_MAX_IMAGE_EDGE=0
VLM_API_IMAGE_FORMAT=PNG
VLM_API_JPEG_QUALITY=95

# ----- 本地后端 ------------------------------------------------------------
# VLM_BACKEND=local 时必须设置
QWEN_VL_PATH=
VLM_LOCAL_DTYPE=bfloat16
VLM_LOCAL_DEVICE_MAP=auto

# ----- 现有变量 ------------------------------------------------------------
OIL_GAS_LOG_LEVEL=INFO
